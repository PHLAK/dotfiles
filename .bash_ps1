source ${HOME}/.bash_formatting
source /usr/share/git/git-prompt.sh

# Show git dirty state (*/+) in PS1
export GIT_PS1_SHOWDIRTYSTATE=1

# Set function to generate PS1
export PROMPT_COMMAND=generatePS1

function generatePS1() {
    # Set prompt color based on previous command exit code (NOTE: Must be first)
    case ${PIPESTATUS[-1]} in
        0 | 130) local PROMPT_COLOR=${FG_BLACK};;
        *)       local PROMPT_COLOR=${FG_RED};;
    esac

    case $(lsb_release --id --short) in
        Arch)   local DISTRO_LOGO="";;
        Debian) local DISTRO_LOGO="";;
        *)      local DISTRO_LOGO="";;
    esac

    local GIT_STATUS="${FG_YELLOW}$(__git_ps1 '(%s)')"

    PS1="${FG_BLUE}${DISTRO_LOGO}"      # DISTRO LOGO
    PS1+="${RESET_FORMAT} "             # <space>
    PS1+="$(user)"                      # USER
    PS1+="${RESET_FORMAT} "             # <space>
    PS1+="${FG_BLACK}@"                 # AT SIGN
    PS1+="${RESET_FORMAT} "             # <space>
    PS1+="$(host)"                      # HOST
    PS1+="${RESET_FORMAT} "             # <space>
    PS1+="$(dockerIndicator)"           # DOCKER INDICATOR
    PS1+="${RESET_FORMAT} "             # <space>
    PS1+="$(workingDirectory)"          # WORKING DIRECTORY
    PS1+="${RESET_FORMAT} "             # <space>
    PS1+="${GIT_STATUS}"                # GIT PS1
    PS1+="${RESET_FORMAT}\n"            # <new line>
    PS1+="$(timestamp)"                 # TIMESTAMP
    PS1+="${RESET_FORMAT} "             # <space>
    PS1+="${BOLD}${PROMPT_COLOR}❭"      # PROMPT
    PS1+="${RESET_FORMAT} "             # <space>
}

function user() {
    [[ "${USER}" == "root" ]] && echo -n "${BOLD}${FG_RED}\u" || echo -n "${BOLD}${FG_GREEN}\u"

    echo ${RESET_FORMAT}
}

function host() {
    [[ -n "${SSH_CLIENT}" ]] && echo -n "${BOLD}${FG_RED}\h" || echo -n "${BOLD}${FG_BLUE}\h"

    echo ${RESET_FORMAT}
}

function dockerIndicator() {
    local DOCKER_SOCKET="/var/run/docker.sock"

    if [[ -f "docker-composer.yml" ]] || [[ -f "docker-compose.yaml" ]]; then
        if [[ -n "$(docker compose ps --services --filter 'status=running')" ]]; then
            echo -n "${FG_CYAN}⬢"
        elif [[ -r "${DOCKER_SOCKET}" ]] && [[ -n "$(docker --host unix://${DOCKER_SOCKET} compose ps --services --filter 'status=running')" ]]; then
            echo -n "${FG_RED}⬢"
        else
            echo -n "${FG_CYAN}⬡"
        fi

        echo "${RESET_FORMAT}"
    fi
}

function workingDirectory() {
    if [[ ${PWD} = ${HOME}/workspace/* ]] && git rev-parse --is-inside-work-tree &>/dev/null; then
        echo -n "${FG_MAGENTA}${PWD#${HOME}/workspace/*/}"
    else
        echo -n "${FG_MAGENTA}$(dirs)"
    fi

    echo "${RESET_FORMAT}"
}

function timestamp() {
    echo -n "${FG_CYAN}\D{%b %d}"
    echo -n " ${FG_BLACK}•${RESET_FORMAT} "
    echo "${FG_CYAN}\D{%I:%M %p}"
}
